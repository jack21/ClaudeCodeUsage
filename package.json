{
  "name": "claude-code-usage",
  "displayName": "Claude Code Usage",
  "description": "Monitor Claude Code usage and costs in VSCode status bar",
  "version": "2.1.1",
  "publisher": "GrowthJack",
  "author": "GrowthJack",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jack21/ClaudeCodeUsage.git"
  },
  "bugs": {
    "url": "https://github.com/jack21/ClaudeCodeUsage/issues"
  },
  "homepage": "https://github.com/jack21/ClaudeCodeUsage",
  "keywords": [
    "claude",
    "claude-code",
    "usage",
    "cost",
    "monitoring",
    "ai",
    "anthropic",
    "token",
    "status-bar"
  ],
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "icon": "icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Claude Code Usage",
      "properties": {
        "claudeCodeUsage.dataDirectory": {
          "type": "string",
          "default": "",
          "description": "Custom Claude data directory path (leave empty for auto-detection)"
        },
        "claudeCodeUsage.language": {
          "type": "string",
          "enum": [
            "auto",
            "en",
            "zh-TW",
            "zh-CN",
            "ja",
            "ko",
            "pt-BR"
          ],
          "default": "auto",
          "description": "Display language (auto-detection or manual selection). All other settings now live in the dashboard's ⚙ Settings tab (Show Usage Details)."
        },
        "claudeCodeUsage.advice.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for the 'Get AI Advice' feature (used when advice.backend = api). Leave empty to use the subscription backend. Other advice options live in the dashboard's ⚙ Settings tab."
        }
      }
    },
    "commands": [
      {
        "command": "claudeCodeUsage.refresh",
        "title": "Refresh Usage Data",
        "category": "Claude Code Usage"
      },
      {
        "command": "claudeCodeUsage.showDetails",
        "title": "Show Usage Details",
        "category": "Claude Code Usage"
      },
      {
        "command": "claudeCodeUsage.openSettings",
        "title": "Open Settings",
        "category": "Claude Code Usage"
      },
      {
        "command": "claudeCodeUsage.refreshPricing",
        "title": "Refresh Token Pricing",
        "category": "Claude Code Usage"
      },
      {
        "command": "claudeCodeUsage.getAdvice",
        "title": "Get AI Usage Advice",
        "category": "Claude Code Usage"
      },
      {
        "command": "claudeCodeUsage.showLogs",
        "title": "Show Diagnostic Logs",
        "category": "Claude Code Usage"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test out/test/*.test.js"
  },
  "devDependencies": {
    "@types/glob": "^9.0.0",
    "@types/node": "24.0.15",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.8.3"
  }
}
